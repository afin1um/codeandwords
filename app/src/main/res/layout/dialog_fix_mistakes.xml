<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Работа над ошибками"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#F44336"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvMistakesLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Осталось исправить: 0"
        android:layout_gravity="center_horizontal"
        android:textColor="@android:color/darker_gray"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvWordToTranslate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Слово"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="#2196F3"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilFixInput"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Введите правильный ответ">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etFixInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textNoSuggestions|textVisiblePassword"
            android:imeOptions="actionDone"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFixCheck"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Исправить"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        app:cornerRadius="12dp" />

</LinearLayout>