<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#0D202B"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="#31414D"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="14dp"
        android:paddingEnd="12dp"
        android:paddingBottom="14dp">

        <ImageButton
            android:id="@+id/btnSpeak"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_round_speaker"
            android:contentDescription="Озвучить"
            android:padding="8dp"
            android:src="@drawable/ic_speaker_custom"
            android:tint="#27B8FF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commit"
                android:textColor="#F3F8FB"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="фиксация"
                android:textColor="#7E8F99"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvTranscription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="[kəˈmɪt]"
                android:textColor="#5C6D78"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNotes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:text="Make a commit often."
                android:textColor="#97A8B3"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSlowSpeak"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:minWidth="0dp"
                android:text="Медленно"
                android:textAllCaps="false"
                android:textColor="#35B5FF"
                app:cornerRadius="14dp"
                app:strokeColor="#36505D"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Удалить"
            android:padding="4dp"
            android:src="@drawable/ic_delete_custom"
            android:tint="#F35F68" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>