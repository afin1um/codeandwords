<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/team_bg"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:background="@color/team_toolbar_bg"
        android:paddingStart="12dp"
        android:paddingTop="18dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnBackTeamDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/team_toolbar_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Команда"
            android:textColor="@color/team_toolbar_title"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/tvTeamDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Команда"
            android:textColor="@color/team_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_team_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTeamChallengeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Задание команды"
                android:textColor="@color/team_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTeamChallengeTarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Цель: 100"
                android:textColor="@color/team_text_secondary"
                android:textSize="15sp" />

            <ProgressBar
                android:id="@+id/progressTeamChallenge"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="14dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/team_progress_fill"
                android:progressBackgroundTint="@color/team_progress_bg" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Прогресс участников"
            android:textColor="@color/team_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerTeamProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp" />

    </LinearLayout>

</LinearLayout>