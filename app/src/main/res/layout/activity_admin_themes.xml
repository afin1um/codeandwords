<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/app_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBackAdminThemes"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Назад"
                android:padding="8dp"
                android:src="@drawable/ic_back_arrow_custom"
                app:tint="@color/app_text_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Темы"
                android:textColor="@color/app_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Создание, редактирование, удаление тем и просмотр теории"
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="@color/app_card_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_blue"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Данные темы"
                    android:textColor="@color/app_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilThemeTitle"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Название темы"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_blue"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etThemeTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilThemeDescription"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Описание темы"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_blue"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etThemeDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <Spinner
                    android:id="@+id/spDifficulty"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/app_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveTheme"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/app_blue"
                    android:text="СОЗДАТЬ ТЕМУ И ТЕОРИЮ"
                    android:textColor="@color/app_text_on_accent"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearTheme"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/app_card_stroke"
                    android:text="ОЧИСТИТЬ"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="СОЗДАННЫЕ ТЕМЫ"
            android:textColor="@color/app_text_muted"
            android:textSize="13sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminThemes"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <ProgressBar
            android:id="@+id/progressAdminThemes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>