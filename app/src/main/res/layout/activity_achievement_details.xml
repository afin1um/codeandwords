<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <ImageButton
            android:id="@+id/btnBackAchievement"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Назад"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/app_text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvAchievementDetailsScreenTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Достижение"
            android:textColor="@color/app_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBackAchievement"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBackAchievement"
            app:layout_constraintTop_toTopOf="@id/btnBackAchievement" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAchievementDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            app:cardBackgroundColor="@color/app_card_bg"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_card_stroke"
            app:strokeWidth="1dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBackAchievement">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="28dp"
                android:paddingEnd="22dp"
                android:paddingBottom="24dp">

                <FrameLayout
                    android:layout_width="148dp"
                    android:layout_height="148dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="138dp"
                        android:layout_height="138dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="@color/app_surface_green"
                        app:cardCornerRadius="69dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/app_green"
                        app:strokeWidth="3dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivAchievementLarge"
                                android:layout_width="92dp"
                                android:layout_height="92dp"
                                android:layout_gravity="center"
                                android:contentDescription="Достижение"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_achievement_default" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <ImageView
                        android:id="@+id/ivAchievementLock"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_app_close_button"
                        android:padding="7dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:tint="@color/app_text_secondary" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvAchievementStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Получено"
                    android:textColor="@color/app_green"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAchievementTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Название достижения"
                    android:textColor="@color/app_text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAchievementDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Описание достижения"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvAchievementXpReward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_app_empty_state"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="+20 XP"
                    android:textColor="@color/profile_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="24dp"
                    android:background="@color/app_divider" />

                <TextView
                    android:id="@+id/tvAchievementConditionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="УСЛОВИЕ"
                    android:textColor="@color/app_text_muted"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAchievementCondition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Продолжайте учиться, чтобы открыть это достижение."
                    android:textColor="@color/app_text_primary"
                    android:textSize="15sp" />

                <ProgressBar
                    android:id="@+id/progressAchievementDetails"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="9dp"
                    android:layout_marginTop="22dp"
                    android:max="1"
                    android:progress="0"
                    android:progressBackgroundTint="@color/app_divider"
                    android:progressTint="@color/app_green" />

                <TextView
                    android:id="@+id/tvAchievementProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:text="0 / 1"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>