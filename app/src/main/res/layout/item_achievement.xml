<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardAchievementRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/app_card_bg"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/app_card_stroke"
    app:strokeWidth="1dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivAchievementArrow"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="Открыть"
            android:padding="5dp"
            android:rotation="180"
            android:src="@drawable/ic_back_arrow_custom"
            app:tint="@color/app_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="230dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="14dp"
            android:paddingEnd="28dp"
            android:paddingBottom="14dp">

            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="76dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardIconCircle"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@color/app_surface_blue"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/app_blue"
                    app:strokeWidth="2dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/ivAchievementIcon"
                            android:layout_width="46dp"
                            android:layout_height="46dp"
                            android:layout_gravity="center"
                            android:contentDescription="Достижение"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_achievement_default" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <ImageView
                    android:id="@+id/ivLock"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_app_close_button"
                    android:padding="5dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:tint="@color/app_text_secondary"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_app_empty_state"
                android:paddingStart="9dp"
                android:paddingTop="4dp"
                android:paddingEnd="9dp"
                android:paddingBottom="4dp"
                android:text="НОВОЕ"
                android:textColor="@color/app_orange"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:text="Название"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:text="Описание достижения"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvXpReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="+20 XP"
                android:textColor="@color/profile_gold"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressBarAchievement"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="0"
                android:progressBackgroundTint="@color/app_divider"
                android:progressTint="@color/app_blue" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0 / 10"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="В процессе"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

        </LinearLayout>
    </FrameLayout>

</com.google.android.material.card.MaterialCardView>