<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/app_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBackAdminWords"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Назад"
                android:padding="8dp"
                android:src="@drawable/ic_back_arrow_custom"
                app:tint="@color/app_text_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Термины"
                android:textColor="@color/app_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Создание, редактирование, удаление и просмотр терминов по теме"
            android:textColor="@color/app_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdminBulkWords"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/app_card_bg"
            android:text="МАССОВОЕ ДОБАВЛЕНИЕ ТЕРМИНОВ"
            android:textColor="@color/app_text_primary"
            android:textStyle="bold"
            app:cornerRadius="18dp"
            app:strokeColor="@color/app_orange"
            app:strokeWidth="2dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/app_card_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/app_green"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Данные термина"
                    android:textColor="@color/app_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spThemesForWord"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/app_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTerm"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Термин"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_green"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTerm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTranslation"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Перевод"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_green"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTranslation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTranscription"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Транскрипция"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_green"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTranscription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDefinition"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Определение"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_green"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDefinition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilExample"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Пример"
                    app:boxBackgroundColor="@color/app_bg"
                    app:boxStrokeColor="@color/app_green"
                    app:hintTextColor="@color/app_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExample"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"
                        android:textColor="@color/app_text_primary"
                        android:textColorHint="@color/app_text_secondary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveWord"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/app_green"
                    android:text="СОХРАНИТЬ ТЕРМИН"
                    android:textColor="@color/app_text_dark"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearWord"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/app_card_stroke"
                    android:text="ОЧИСТИТЬ"
                    android:textColor="@color/app_text_primary"
                    android:textStyle="bold"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="ТЕРМИНЫ ВЫБРАННОЙ ТЕМЫ"
            android:textColor="@color/app_text_muted"
            android:textSize="13sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminWords"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:overScrollMode="never" />

        <ProgressBar
            android:id="@+id/progressAdminWords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>