<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="18dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/app_card_bg"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/app_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvThemeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Frontend Development"
            android:textColor="@color/app_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="Frontend Development" />

        <TextView
            android:id="@+id/tvDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_difficulty"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp"
            android:text="Средний"
            android:textColor="@color/app_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Средний" />

        <TextView
            android:id="@+id/tvThemeDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="2dp"
            android:text="Изучение HTML, CSS, JavaScript и React."
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp"
            tools:text="Изучение HTML, CSS, JavaScript и React." />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>