<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_team_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <CheckBox
        android:id="@+id/cbSelectableFriend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/team_progress_fill" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSelectableFriendUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="username"
            android:textColor="@color/team_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSelectableFriendXp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 XP"
            android:textColor="@color/team_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>