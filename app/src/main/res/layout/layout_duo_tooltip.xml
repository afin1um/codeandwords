<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_stat_card"
    android:elevation="8dp"
    android:gravity="center"
    android:minWidth="220dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvDuoEn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/app_blue"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDuoTranscription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp"
        android:textColor="@color/tooltip_transcription"
        android:textSize="14sp"
        android:textStyle="italic" />

    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="@color/tooltip_divider" />

    <TextView
        android:id="@+id/tvDuoRu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/tooltip_translation"
        android:textSize="16sp" />

    <ImageButton
        android:id="@+id/btnSpeak"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Прослушать"
        android:src="@android:drawable/ic_lock_silent_mode_off"
        app:tint="@color/app_blue" />

</LinearLayout>