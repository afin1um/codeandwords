<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.CodeAndWords" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Main palette -->
        <item name="colorPrimary">@color/app_blue</item>
        <item name="colorPrimaryVariant">@color/app_blue</item>
        <item name="colorOnPrimary">@color/app_text_on_accent</item>

        <item name="colorSecondary">@color/app_green</item>
        <item name="colorSecondaryVariant">@color/app_green</item>
        <item name="colorOnSecondary">@color/app_text_dark</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:navigationBarColor">@color/app_bg</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>

        <!-- Important for dark status/nav icons -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar"
            tools:targetApi="o_mr1">true</item>

        <!-- Material components defaults -->
        <item name="materialButtonStyle">@style/Widget.CodeAndWords.Button</item>
        <item name="textInputStyle">@style/Widget.CodeAndWords.TextInputLayout</item>

    </style>

    <style name="Theme.CodeAndWords.AchievementPopup" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/app_bg</item>
    </style>

    <style name="Widget.CodeAndWords.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.CodeAndWords.Button.Green" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/app_green</item>
        <item name="android:textColor">@color/app_text_dark</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CodeAndWords.Button.Blue" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/app_blue</item>
        <item name="android:textColor">@color/app_text_on_accent</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CodeAndWords.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/app_card_bg</item>
        <item name="strokeColor">@color/app_card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CodeAndWords.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/app_card_bg</item>
        <item name="boxStrokeColor">@color/app_card_stroke</item>
        <item name="hintTextColor">@color/app_text_secondary</item>
        <item name="android:textColorHint">@color/app_text_secondary</item>
    </style>

    <style name="AvatarIconTab">
        <item name="android:layout_width">64dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>

</resources>