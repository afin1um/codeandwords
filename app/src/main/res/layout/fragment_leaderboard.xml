<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvLeagueTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Все лиги"
                android:textColor="@color/app_text_primary"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLeagueSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Все участники рейтинга"
                android:textColor="@color/app_text_secondary"
                android:textSize="15sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/leagueFilterContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLeagueInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvLeagueIcon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_league_icon"
                            android:gravity="center"
                            android:text="🌍"
                            android:textSize="34sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvSelectedLeague"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Все лиги"
                                android:textColor="@color/app_text_primary"
                                android:textSize="19sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvLeagueUsersCount"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0 участников"
                                android:textColor="@color/app_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMyLeagueInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Ваша лига: —"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/progressLeague"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/progress_league" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/topThreeContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:baselineAligned="false"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/topSecondBlock"
                    android:layout_width="0dp"
                    android:layout_height="154dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <FrameLayout
                        android:id="@+id/topSecondAvatarContainer"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_leaderboard_avatar_circle"
                        android:clipToOutline="true"
                        android:padding="4dp">

                        <com.example.codeandwords.ui.profile.AvatarPreviewView
                            android:id="@+id/topSecondAvatarView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleX="0.92"
                            android:scaleY="0.92" />

                        <TextView
                            android:id="@+id/topSecondAvatarFallback"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_leaderboard_avatar_fallback_circle"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@color/app_text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTopSecondName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="—"
                        android:textColor="@color/app_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTopSecondXp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0 XP"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/topFirstBlock"
                    android:layout_width="0dp"
                    android:layout_height="186dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <FrameLayout
                        android:id="@+id/topFirstAvatarContainer"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:background="@drawable/bg_leaderboard_avatar_circle"
                        android:clipToOutline="true"
                        android:padding="2dp">

                        <com.example.codeandwords.ui.profile.AvatarPreviewView
                            android:id="@+id/topFirstAvatarView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleX="0.92"
                            android:scaleY="0.92" />

                        <TextView
                            android:id="@+id/topFirstAvatarFallback"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_leaderboard_avatar_fallback_circle"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/app_text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTopFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="—"
                        android:textColor="@color/app_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTopFirstXp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0 XP"
                        android:textColor="#FFC107"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/topThirdBlock"
                    android:layout_width="0dp"
                    android:layout_height="148dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <FrameLayout
                        android:id="@+id/topThirdAvatarContainer"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/bg_leaderboard_avatar_circle"
                        android:clipToOutline="true"
                        android:padding="4dp">

                        <com.example.codeandwords.ui.profile.AvatarPreviewView
                            android:id="@+id/topThirdAvatarView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleX="0.92"
                            android:scaleY="0.92" />

                        <TextView
                            android:id="@+id/topThirdAvatarFallback"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_leaderboard_avatar_fallback_circle"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/app_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvTopThirdName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="—"
                        android:textColor="@color/app_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTopThirdXp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="0 XP"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvListTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Участники лиги"
                android:textColor="@color/app_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                tools:listitem="@layout/item_leaderboard" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/pbLeaderboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>