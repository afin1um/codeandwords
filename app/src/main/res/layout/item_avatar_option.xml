<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/optionRoot"
    android:layout_width="match_parent"
    android:layout_height="156dp"
    android:layout_margin="8dp"
    android:background="@drawable/bg_avatar_option"
    android:padding="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_avatar_option_inner"
        android:clipToOutline="true"
        android:padding="6dp">

        <com.example.codeandwords.ui.profile.AvatarPreviewView
            android:id="@+id/avatarOptionPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</FrameLayout>