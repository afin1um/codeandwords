<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/profileHeaderContainer"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:background="@color/profile_header_bg">

            <LinearLayout
                android:id="@+id/profileHeaderContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/profile_header_bg"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="44dp"
                android:paddingEnd="24dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/headerInfoBlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sandra"
                            android:textColor="@color/profile_header_text"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="mail@example.com"
                            android:textColor="@color/profile_header_subtitle"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/headerActions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="@color/profile_action_bg"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageButton
                                android:id="@+id/btnEditProfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Редактировать профиль"
                                android:padding="12dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_manage"
                                android:tint="@color/profile_header_text" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            app:cardBackgroundColor="@color/profile_action_bg"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageButton
                                android:id="@+id/btnToggleTheme"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Переключить тему"
                                android:padding="12dp"
                                android:scaleType="centerInside"
                                android:src="@drawable/ic_theme_moon"
                                android:tint="@color/profile_header_text" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            app:cardBackgroundColor="@color/profile_action_bg"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageButton
                                android:id="@+id/btnEditAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Изменить аватар"
                                android:padding="12dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_menu_edit"
                                android:tint="@color/profile_header_text" />
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="10dp"
                            app:cardBackgroundColor="@color/profile_action_bg"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <ImageButton
                                android:id="@+id/btnLogout"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Выйти"
                                android:padding="12dp"
                                android:scaleType="centerInside"
                                android:src="@android:drawable/ic_lock_power_off"
                                android:tint="@color/profile_header_text" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </RelativeLayout>

                <FrameLayout
                    android:id="@+id/avatarPreviewHolder"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    android:layout_weight="1"
                    android:background="@color/profile_header_bg">

                    <com.example.codeandwords.ui.profile.AvatarPreviewView
                        android:id="@+id/avatarPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/app_bg"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/tvHandle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@username"
                android:textColor="@color/app_text_muted"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvCoursesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/app_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Освоено тем"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvMedalsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/app_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Достижения"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTotalXP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/app_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Очки"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenPersonalDictionary"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:backgroundTint="@color/app_card_bg"
                android:text="ОТКРЫТЬ ЛИЧНЫЙ СЛОВАРЬ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/app_card_stroke"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenStudySchedule"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_card_bg"
                android:text="ОТКРЫТЬ ГРАФИК ЗАНЯТИЙ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/app_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenStatistics"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_card_bg"
                android:text="ОТКРЫТЬ СТАТИСТИКУ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/app_green"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenTeam"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_card_bg"
                android:text="КОМАНДА И ДРУЗЬЯ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:strokeColor="@color/app_green"
                app:strokeWidth="2dp" />

            <!-- ✅ НОВАЯ КНОПКА — НАЙТИ ДРУЗЕЙ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindFriends"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_blue"
                android:text="🔍  НАЙТИ ДРУЗЕЙ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_on_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenAdminPanel"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/app_card_bg"
                android:text="АДМИН-ПАНЕЛЬ"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="18dp"
                app:strokeColor="@color/app_orange"
                app:strokeWidth="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="ОБЗОР"
                android:textColor="@color/app_text_muted"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/app_card_bg"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvLevelValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="@color/app_text_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Уровень"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvWordsLearnedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/app_text_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Слов изучено"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvMasteredThemesValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/app_text_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Тем освоено"
                                android:textColor="@color/app_text_secondary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="16dp"
                        android:background="@color/app_divider" />

                    <TextView
                        android:id="@+id/tvLeagueValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥉 Бронзовая лига"
                        android:textColor="@color/league_bronze"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLeagueDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Начало пути"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="14sp" />

                    <ProgressBar
                        android:id="@+id/progressBarXP"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="18dp"
                        android:max="100"
                        android:progress="0"
                        android:progressBackgroundTint="@color/app_divider"
                        android:progressTint="@color/profile_gold" />

                    <TextView
                        android:id="@+id/tvXpCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0 / 100 XP"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutAchievementsHeader"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="30dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ДОСТИЖЕНИЯ"
                    android:textColor="@color/app_text_muted"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="@color/app_text_muted"
                    android:textSize="34sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMedals"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="4dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:paddingEnd="8dp" />

            <TextView
                android:id="@+id/tvMedalsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_app_empty_state"
                android:gravity="center"
                android:padding="18dp"
                android:text="Пока нет достижений"
                android:textColor="@color/app_text_secondary"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>