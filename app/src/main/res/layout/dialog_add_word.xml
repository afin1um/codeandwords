<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/etNewWord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Слово (напр. Git)"
        android:textColor="@color/dict_dialog_text"
        android:textColorHint="@color/dict_dialog_hint" />

    <EditText
        android:id="@+id/etNewTranslation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Перевод"
        android:textColor="@color/dict_dialog_text"
        android:textColorHint="@color/dict_dialog_hint" />

    <EditText
        android:id="@+id/etNewTranscription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Транскрипция"
        android:textColor="@color/dict_dialog_text"
        android:textColorHint="@color/dict_dialog_hint" />

    <EditText
        android:id="@+id/etNewNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Заметки (пример)"
        android:textColor="@color/dict_dialog_text"
        android:textColorHint="@color/dict_dialog_hint" />

</LinearLayout>