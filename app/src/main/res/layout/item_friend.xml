<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_team_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvAvatarLetter"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@color/app_blue"
        android:gravity="center"
        android:text="S"
        android:textColor="@color/app_text_on_accent"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFriendUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sandra"
            android:textColor="@color/team_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFriendXp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0 XP"
            android:textColor="@color/team_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>